24736236493_n.jpg?stp=dst-jpg_e15&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi41NDB4OTYwLnNkci5mMjkzNTAifQ&_nc_ht=scontent-iad3-1.cdninstagram.com&_nc_cat=107&_nc_ohc=kggwnnh8JF0Q7kNvgEOUMDC&gid=4f203abbba48488d9d6fa9636a469376&edm=AEhyXUkBAAAA&ccb=7-5&ig_cache_key=MzQyMDY3NTkxMDk0ODAwMDU5MA%3D%3D.2-ccb7-5&oh=00_AYCbE6Y7qrkXD0HlYVUMCdH0nA2WaVydJn8Guv7jF_DMYw&oe=66B0AEB9&_nc_sid=8f1549","caption":"Berikut ini kegiatan Mingguan Bagian Hukum Setda Kota Bekasi","post_time":1721996386,"owner":"8007665629","cdn_image":"//cdn.jsdelivr.net/gh/pemkotbekasi/photo_gallery/picture/8007665629/C94rp4TypNO.jpg"},{"id":"C9wAay4SXG8","image":"https://scontent-iad3-2.cdninstagram.com/v/t51.29350-15/452385021_359502773852459_1328758928633552341_n.jpg?stp=dst-jpg_e15&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi41NDB4OTYwLnNkci5mMjkzNTAifQ&_nc_ht=scontent-iad3-2.cdninstagram.com&_nc_cat=111&_nc_ohc=Cv2aUGjXn3UQ7kNvgHJCuN6&edm=AEhyXUkBAAAA&ccb=7-5&ig_cache_key=MzQxODIzMzk1ODUxMjAzMDE0MA%3D%3D.2-ccb7-5&oh=00_AYD8SY-NlNimYwU5DmIaYwDSRJezEXt7oYnQkIGt8kXjfg&oe=66B0BBE1&_nc_sid=8f1549","caption":"Halloo sobat hukum semuaa, saat ini pemerintah kota bekasi telah menetapkan PERATURAN DAERAH NOMOR 3 TAHUN 2023 Tentang Perlindungan Anak.. \n\nNamun pencegahan kekerasan terhadap anak tidak hanya tergantung pada diterbitkannya regulasi yang melindungi anak, tetapi juga memerlukan peran serta masyarakat yang aktif dalam mencegah dan menanggulangi kekerasan, keluarga adalah tempat pertama dan utama bagi anak anak dimana mereka belajar dan tumbuh, yuk mari seluruh lapisan masyarakat kota bekasi bersama sama berkolaborasi dalam mewujudkan perlindungan anak yang efektif dengan demikian anak anak kita dapat tumbuh dan berkembang dalam lingkungan yang aman dan seimbang.\n#pjwalikotabekasi\n#Kota Kayak Anak (KLA) \n#dpppa_kotabekasi\n#Jdihnindonesia \n#penyuluhanhukum\n#kotabekasi","post_time":1721705405,"owner":"8007665629","cdn_image":"//cdn.jsdelivr.net/gh/pemkotbekasi/photo_gallery/picture/8007665629/C9wAay4SXG8.jpg"},{"id":"C9tLT2wS7pF","image":"https://scontent-iad3-1.cdninstagram.com/v/t51.29350-15/452332330_372795815860502_7194255931423549213_n.jpg?stp=dst-jpg_e15&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi40NDR4NDQ0LnNkci5mMjkzNTAifQ&_nc_ht=scontent-iad3-1.cdninstagram.com&_nc_cat=102&_nc_ohc=HQr8uq1c25EQ7kNvgG74aK5&gid=4f203abbba48488d9d6fa9636a469376&edm=AEhyXUkBAAAA&ccb=7-5&ig_cache_key=MzQxNzQzNzQzNTIxODA4MjM3Mw%3D%3D.2-ccb7-5&oh=00_AYDrRrXQjRfMscqVbDvJyGPrKFeBxt_HBwJsw58tV5SjCQ&oe=66B0C610&_nc_sid=8f1549","caption":"Sobat hukum...jangan sampsi lupa 3 asas hukum ini ya gaes","post_time":1721610319,"owner":"8007665629","cdn_image":"//cdn.jsdelivr.net/gh/pemkotbekasi/photo_gallery/picture/8007665629/C9tLT2wS7pF.jpg"},{"id":"C9m2cbNSR4x","image":"https://scontent-iad3-2.cdninstagram.com/v/t51.29350-15/451814625_3407011412941839_679672382489417239_n.jpg?stp=dst-jpg_e15&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi40NDR4Nzg5LnNkci5mMjkzNTAifQ&_nc_ht=scontent-iad3-2.cdninstagram.com&_nc_cat=103&_nc_ohc=FwX0v_CXvK0Q7kNvgGnaCyW&gid=4f203abbba48488d9d6fa9636a469376&edm=AEhyXUkBAAAA&ccb=7-5&ig_cache_key=MzQxNTY1NjgxNTI3Nzk3MzA0MQ%3D%3D.2-ccb7-5&oh=00_AYA5p7dl-bfxYg4hyNtbsag6rE_Dm3v8GQj2Q8i7u5UjdA&oe=66B096E1&_nc_sid=8f1549","caption":"Kegiatan Bagian Hukum Setda Kota Bekasi tanggal 15-19 Juli 2024","post_time":1721398059,"owner":"8007665629","cdn_image":"//cdn.jsdelivr.net/gh/pemkotbekasi/photo_gallery/picture/8007665629/C9m2cbNSR4x.jpg"},{"id":"C9UYybey-AP","image":"https://scontent-iad3-2.cdninstagram.com/v/t51.29350-15/450634520_1013409710372778_2118161657634548456_n.jpg?stp=dst-jpg_e15&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi40NDR4Nzg5LnNkci5mMjkzNTAifQ&_nc_ht=scontent-iad3-2.cdninstagram.com&_nc_cat=106&_nc_ohc=cJ07D5JjIcIQ7kNvgFn40Ds&gid=4f203abbba48488d9d6fa9636a469376&edm=AEhyXUkBAAAA&ccb=7-5&ig_cache_key=MzQxMDQ1OTgzNjQyNDExODI4Nw%3D%3D.2-ccb7-5&oh=00_AYBthxG5CFpMRCNrkkaqHIaSdmzsEqChxxSdiVk6mlWx-g&oe=66B08EF4&_nc_sid=8f1549","caption":"Hallo sobat Hukum kota Bek