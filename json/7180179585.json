[{"current_url":"https://www.instagram.com/kelurahan_kayuringinjaya/?_showcaption=true","snapshot_date":1756227567174,"id":"DLZCLhducCk","image":"https://scontent-iad3-1.cdninstagram.com/v/t51.75761-15/502339816_18314960461235586_918207057739653077_n.jpg?stp=dst-jpg_e35_s720x720_sh0.08_tt6&_nc_cat=110&ig_cache_key=MzY2Mzk2OTM1OTc4MjA2ODM4OA%3D%3D.3-ccb1-7&ccb=1-7&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjE5MjB4MTA4MC5zZHIuQzMifQ%3D%3D&_nc_ohc=tJjUD83xjB0Q7kNvwGaPUKy&_nc_oc=AdlsfISM0fKARR-bkk5fvy-AMaxHfApdFTjHIoJkvJREUf3KHtFIftlSFGpabvCNF8s&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=scontent-iad3-1.cdninstagram.com&_nc_gid=vNTsclS_cZVbA9iLRUs1aw&oh=00_AfWWD6fnCm3aIJbQ3qTb0GwTOOZcGG5NC5Hw05cOQwoa4g&oe=68B3A6A9","caption":"✨ Aparatur Kecamatan Bekasi Selatan Meriahkan Pawai Akbar 1 Muharram 1447 H ✨\n\nDalam rangka menyambut Tahun Baru Islam 1447 Hijriah, aparatur Kecamatan Bekasi Selatan turut ambil bagian dalam Pawai Akbar 1 Muharram bersama pelajar, ormas Islam, majelis taklim, dan unsur masyarakat se-Kota Bekasi.\n\nPawai dimulai dari Plaza Pemkot Bekasi dan berakhir di Alun-Alun M. Hasibuan, berlangsung penuh semangat hijrah, kekompakan, dan kebersamaan.\n\nKemeriahan makin terasa dengan iringan marching band, serta penampilan unik dari peserta Kecamatan Bekasi Selatan yang membawa durian dan rengginang sebagai simbol kekayaan kuliner dan kearifan lokal.\n\n🌙 Semangat hijrah menuju pribadi unggul\n🤝 Menguatkan ukhuwah antara ulama, pemerintah, dan masyarakat\n🏙️ Demi Kota Bekasi yang makin nyaman kotanya dan makin sejahtera warganya\n\n@mastriadhianto \n@harris.bobihoe \n@karyasukmajaya \n@isnainihd \n@pemkot_bekasi \n@diskominfobekasi \n@humaskotabekasi \n\n#1Muharram1447H\n#TahunBaruIslam1447H\n#Hijrah1447H\n#PawaiAkbarBekasi\n#Pawai1Muharram\n#KecamatanBekasiSelatan\n#PemkotBekasi\n#BekasiBertakwa\n#UkhuwahIslamiyah\n#BekasiSejahtera","post_time":1750999261,"owner":"7180179585","username":"kecamatanbekasiselatan","comment_count":2,"like_count":71,"cdn_image":