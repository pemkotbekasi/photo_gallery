[{"current_url":"https://www.instagram.com/kecamatanbekasiselatan/?_showcaption=true","snapshot_date":1753776281492,"id":"DGnL2MGSW6c","image":"https://scontent-iad3-1.cdninstagram.com/v/t51.2885-15/482256319_17849959647409784_7305407853920051019_n.jpg?stp=dst-jpg_e35_p720x720_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6IkNBUk9VU0VMX0lURU0uaW1hZ2VfdXJsZ2VuLjEwMTJ4MTI2NS5zZHIuZjc1NzYxLmRlZmF1bHRfaW1hZ2UuYzIifQ&_nc_ht=scontent-iad3-1.cdninstagram.com&_nc_cat=108&_nc_oc=Q6cZ2QGWUVAedi9AFFAUcGS8ovcdRT_ey7iSUM-ZlM9h1gwGRQKyHJdMazeIljSDWVpIOvk&_nc_ohc=9uAtK1NVWB4Q7kNvwEf9zg9&_nc_gid=QJIJjhd6u7nrZKtFsyXcgA&edm=APoiHPcBAAAA&ccb=7-5&ig_cache_key=MzU3Nzg4MDUxMjc3NTc0NDU3MQ%3D%3D.3-ccb7-5&oh=00_AfTXF1-uJIPYasTBX4PDl9W_eOSXHcKPMYyxX1HuOb9OBg&oe=688E61A1&_nc_sid=22de04","caption":"Berdasarkan hasil rapat koordinasi dan tinjauan lapangan pada hari Rabu lalu, Plt. Kepala UPTD LLAP Bekasi Selatan beserta anggota melaksanakan kegiatan penertiban parkir dan Pedagang Kaki Lima (PKL) di Simpang Pekayon Bekasi Selatan, serta pemasangan barrier beton U-Turn depan Mall Pakuwon guna mengurangi kepadatan dan mengoptimalkan manajemen lalu lintas disekitar kawasan tersebut pada jam-jam sibuk.\n\nTurut hadir Kepala Dinas Perhubungan Kota Bekasi, Camat Bekasi Selatan, Satpol PP serta jajaran samping.\n\nKegiatan penertiban parkir liar dan Pedagang Kaki Lima (PKL) ini akan dilaksanakan secara berkelanjutan demi menciptakan kenyamanan dan keselamatan bagi seluruh pengguna jalan yang melewati kawasan tersebut.\n\nJum’at, 28 Februari 2025\n\n@mastriadhianto @harris.bobihoe @pemkot_bekasi\n\n#dishubbekasikota #dishubjabar #pemkotbekasi #bptjkemenhub #diskominfo #infobekasi #kecamatanbekasiselatan #pjwalikotabekasi #kotabekasi #pakuwon","post_time":1740736617,"owner":"72256225783","username":"uptdllapbekasiselatan","comment_count":0,"like_count":28,"cdn_image":"//cdn.jsdelivr.net/gh/pemkotbekasi/photo_gallery/picture/72256225783/DGnL2MGSW6c.jpg"},{"current_url":"https://www.instagram.com/kecamatanbekasiselatan/?_sho